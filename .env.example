# Backend
DATABASE_URL=sqlite:///data/simulations.db
SIMULATION_MAX_WORKERS=auto
SIMULATION_DEFAULT_TICK_MINUTES=5
LOG_LEVEL=INFO
# Comma-separated list of allowed browser origins (must be explicit when credentials are used)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI Generation (Claude API)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000
